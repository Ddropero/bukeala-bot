{
  "manifest_version": 3,
  "name": "Bukeala Session Sender v5",
  "version": "5.0.0",
  "description": "v5: CAS heartbeat + auto-envío de sesión cada 5 min para mantener token vivo 24/7.",
  "permissions": ["cookies", "storage", "activeTab", "alarms", "tabs"],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Bukeala session"
  }
}
