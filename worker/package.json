{
  "name": "bukeala-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "kv:create:sessions": "wrangler kv namespace create SESSIONS",
    "kv:create:state": "wrangler kv namespace create STATE",
    "secret:capture": "wrangler secret put CAPTURE_TOKEN",
    "secret:enc": "wrangler secret put ENCRYPTION_KEY",
    "secret:tg": "wrangler secret put TELEGRAM_BOT_TOKEN",
    "secret:chat": "wrangler secret put ALLOWED_CHAT_ID",
    "secret:webhook": "wrangler secret put WEBHOOK_SECRET",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.86.0"
  }
}
